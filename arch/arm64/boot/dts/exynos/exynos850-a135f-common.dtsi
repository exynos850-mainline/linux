/*
 * Samsung Galaxy A13 (A135F) common board device tree source
 */

#include "exynos850.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "Samsung Galaxy A13 (A135F)";
	compatible = "samsung,a135f", "samsung,exynos850";

	aliases {
		serial0 = &serial_0;
	};

	chosen {
		stdout-path = &framebuffer0;
		#address-cells = <2>;
		#size-cells = <1>;
		ranges;
		bootargs = "earlycon= clk_ignore_unused pd_ignore_unused regulator_ignore_unused console=tty0 fbcon=map:0";

		framebuffer0: framebuffer@fa000000 {
			compatible = "simple-framebuffer";
			reg = <0x0 0xfa000000 (1080 * 2408 * 4)>;
			width = <1080>;
			height = <2408>;
			stride = <(1080 * 4)>;
			format = "a8r8g8b8";
			status = "okay";
		};
	};

	// TODO: samsung.
	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x01>;
		ranges;

		ramoops@f0f10000 {
			compatible = "ramoops";
			reg = <0x00 0xf0f10000 0x8000>;
			record-size = <0x2000>;
			console-size = <0x4000>;
			ftrace-size = <0>;
			pmsg-size = <0x2000>;
		};

		bootloader_fb {
			reg = <0x00 0xfa000000 (1080 * 2408 * 4)>;
			no-map;
		};

		abox_dbg@E9400000 {
			compatible = "exynos,abox_dbg";
			reg = <0x00 0xec000000 0x400000>;
		};

		abox-slog {
			compatible = "exynos,abox_slog";
			reg = <0x00 0xe6c00000 0x2800000>;
		};
	};

	rtcclk: clock-rtcclk {
		compatible = "fixed-clock";
		clock-output-names = "rtcclk";
		#clock-cells = <0>;
		clock-frequency = <32768>;
	};
};

&cmu_hsi {
	clocks = <&oscclk>, <&rtcclk>,
		 <&cmu_top CLK_DOUT_HSI_BUS>,
		 <&cmu_top CLK_DOUT_HSI_MMC_CARD>,
		 <&cmu_top CLK_DOUT_HSI_USB20DRD>;
	clock-names = "oscclk", "rtcclk", "dout_hsi_bus",
		      "dout_hsi_mmc_card", "dout_hsi_usb20drd";
};

&mmc_0 {
	status = "okay";
	compatible = "samsung,exynos7-dw-mshc";
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	cap-mmc-highspeed;
	non-removable;
	mmc-hs400-enhanced-strobe;
	card-detect-delay = <200>;
	clock-frequency = <800000000>;
	bus-width = <8>;
	samsung,dw-mshc-ciu-div = <3>;
	samsung,dw-mshc-sdr-timing = <0 4>;
	samsung,dw-mshc-ddr-timing = <2 4>;
	samsung,dw-mshc-hs400-timing = <0 2>;

	pinctrl-names = "default";
	pinctrl-0 = <&sd0_clk_pins &sd0_cmd_pins &sd0_rdqs_pins &sd0_nreset_pins
		     &sd0_bus1_pins &sd0_bus4_pins &sd0_bus8_pins>;
};

&usi_cmgp0 {
	status = "okay";
};

&oscclk {
	clock-frequency = <26000000>;
};

&timer {
	clock-frequency = <26000000>;
};

&rtc {
	status = "disabled";
	clocks = <&cmu_apm CLK_GOUT_RTC_PCLK>, <&rtcclk>;
	clock-names = "rtc", "rtc_src";
};

&spi_1 {
	status = "okay";
};

&serial_0 {
	status = "disabled";
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_pins>;
};

&usbdrd {
	status = "okay";
};

&usbdrd_dwc3 {
	dr_mode = "otg";
	phy-names = "usb2-phy", "usb3-phy";
	usb-role-switch;
};

&usbdrd_phy {
	status = "okay";
	pinctrl-names = "default";
};

&usi_uart {
	status = "disabled";
};

&watchdog_cl0 {
	status = "okay";
};

&watchdog_cl1 {
	status = "okay";
};
