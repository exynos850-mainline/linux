/*
 * Samsung Galaxy A13 (A135F) 4GB RAM variant board device tree source
 * This just configures the memory, and includes the common device source for everything else.
 * Copyright (c), 2026, schoosh212 <superaviation001@gmail.com>
 */

/dts-v1/;

#include "exynos850-a135f-common.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
        model = "Samsung Galaxy A13 (A135F) (4GB)";
        compatible = "samsung,a135f", "samsung,a135f-4gb", "samsung,exynos850";
        #address-cells = <2>;
        #size-cells = <1>;

        memory@8e0000000 {
                device_type = "memory";
                reg = <0x08 0xe0000000 0x20000000>;
        };

        memory@8c0000000 {
                device_type = "memory";
                reg = <0x08 0xc0000000 0x20000000>;
        };

        memory@8a0000000 {
                device_type = "memory";
                reg = <0x08 0xa0000000 0x20000000>;
        };

        memory@880000000 {
                device_type = "memory";
                reg = <0x08 0x80000000 0x20000000>;
        };

        memory@e0d00000 {
                device_type = "memory";
                reg = <0x00 0xe0d00000 0x1f300000>;
        };

        memory@c0000000 {
                device_type = "memory";
                reg = <0x00 0xc0000000 0x20000000>;
        };

        memory@80000000 {
                device_type = "memory";
                reg = <0x00 0x80000000 0x3c900000>;
        };
};
